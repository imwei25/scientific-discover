{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "科研助手",
  "version": "0.2.12",
  "identifier": "com.research.assistant",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": { "script": "npm run dev", "cwd": "../frontend" },
    "beforeBuildCommand": { "script": "npm run build", "cwd": "../frontend" }
  },
  "app": {
    "windows": [
      {
        "title": "科研助手",
        "width": 1200,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "externalBin": ["binaries/sidecar"],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installerHooks": "nsis-hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDEzNjFFNzk1OEFDRTM5QUYKUldTdk9jNktsZWRoRTgwUnpXVmU4Z1JPUlM0UGhJNlNTM016dDlqQU1xNFVCcSttQTArdmYrU2IK",
      "endpoints": [
        "https://github.com/imwei25/scientific-discover/releases/latest/download/latest.json"
      ]
    }
  }
}
